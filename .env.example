# =============================================================================
# OpenAI Configuration
# =============================================================================
# The ONLY required variable. Everything else has working defaults.
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# =============================================================================
# Model Configuration (all optional)
# =============================================================================
# The whole demo runs on gpt-5.4-mini by default, with per-task reasoning
# effort doing the differentiation (chat=medium, background tasks=low).
# You normally don't need to change anything here.
#
# Reasoning effort values: none, minimal, low, medium, high, xhigh.
# The client retries configured fallbacks when a model rejects a value.
#
# IMPORTANT: Chat kinds (fast/deep) always use the SAME underlying model so
# previous_response_id chaining works. Fast vs Deep is reasoning effort only.

# Unified chat model for all chained conversations (fast + deep)
# Default: gpt-5.4-mini
# OPENAI_MODEL_CHAT=gpt-5.4-mini

# Per-task model overrides (each defaults to gpt-5.4-mini)
# OPENAI_MODEL_FAST=
# OPENAI_MODEL_DEEP=
# OPENAI_SUMMARY_MODEL=            # branch merging, on-demand summaries, titles
# OPENAI_MODEL_INTENT=             # retrieval/doc intent classification
# OPENAI_MODEL_STACKS=             # Smart Stacks categorization
# OPENAI_MODEL_FINDER=             # chat finder reranking
# OPENAI_MODEL_CODEX=              # code generation task cards
# OPENAI_MODEL_ASSISTANT=          # cross-chat Assistant artifacts

# Per-task reasoning-effort overrides
# OPENAI_REASONING_DEEP=medium
# OPENAI_REASONING_FAST=low
# OPENAI_REASONING_SUMMARIZE=low
# OPENAI_REASONING_INTENT=low
# OPENAI_REASONING_STACKS=low
# OPENAI_REASONING_FINDER=low
# OPENAI_REASONING_CODEX=medium
# OPENAI_ASSISTANT_REASONING=medium
# OPENAI_ASSISTANT_VERBOSITY=high

# Text-to-speech (document reader)
# Default model: gpt-4o-mini-tts-2025-12-15 | Default voice: nova
# OPENAI_MODEL_TTS=
# OPENAI_TTS_VOICE=

# =============================================================================
# Chat Finder Configuration (optional)
# =============================================================================
# Maximum candidates for lexical pre-filtering (default: 30, max: 60)
# OPENAI_CHAT_FINDER_MAX_CANDIDATES=
# Top K results to return from reranking (default: 5)
# OPENAI_CHAT_FINDER_TOPK=

# =============================================================================
# Redis (optional — recommended for a hosted deployment)
# =============================================================================
# Storage for chat history, codex tasks, and workspace snapshots.
#
# LOCAL DEVELOPMENT: leave blank. The app uses an in-memory store plus a
# browser session cache — no database needed.
#
# HOSTED DEPLOYMENT: Redis is recommended so history survives serverless
# cold starts. Without it the app still works (session-scoped persistence)
# and shows a storage notice. Two env var patterns are supported; set ONE:
#
#   Option 1 — Upstash Redis (what Vercel's marketplace integration injects):
#     UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
#     UPSTASH_REDIS_REST_TOKEN=xxx
#
#   Option 2 — Vercel KV naming:
#     KV_REST_API_URL=https://xxx.upstash.io
#     KV_REST_API_TOKEN=xxx
#
# Data is stored with a 7-day TTL and namespaced per anonymous demo user
# (u:{demo_uid}:...). The URL must be the HTTPS REST endpoint, not redis://.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# =============================================================================
# Vercel Cron / Redis Heartbeat (hosted deployments only)
# =============================================================================
# Protects the daily heartbeat at /api/internal/redis-heartbeat, which keeps
# free-tier Redis databases from being archived for inactivity. Vercel sends
# this automatically as Authorization: Bearer <CRON_SECRET>.
# CRON_SECRET=
